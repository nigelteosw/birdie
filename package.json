{
  "name": "birdie",
  "description": "Authenticated shared mentorship capture for web and MCP clients.",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nigelteosw/birdie.git"
  },
  "bugs": {
    "url": "https://github.com/nigelteosw/birdie/issues"
  },
  "homepage": "https://github.com/nigelteosw/birdie#readme",
  "engines": {
    "node": ">=22.15.0"
  },
  "workspaces": ["backend", "web"],
  "packageManager": "bun@1.3.11",
  "scripts": {
    "build": "bun run --cwd backend build && bun run --cwd web build",
    "test": "bun run --cwd backend test",
    "dev:backend": "bun run --cwd backend dev",
    "dev:web": "bun run --cwd web dev"
  }
}
